{
  "name": "singaporean-bridge",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test -w @sgb/shared",
    "build:shared": "npm run build -w @sgb/shared",
    "dev:server": "npm run dev -w @sgb/server",
    "dev:web": "npm run dev -w @sgb/web",
    "dev": "npm run build:shared && concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
